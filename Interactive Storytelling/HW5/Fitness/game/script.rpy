# ============================================================
# 적합 (Fitness)
# SF 디스토피아 비주얼 노벨 프로토타입
# Engine: Ren'Py 8.x
# ============================================================

# --- 이미지 정의 (1920x1080 강제 스케일) ---
# image bg_white_room = im.Scale("images/bg_white_room.jpg", 1920, 1080)
image bg_dark_room = Solid("#0d0d0d")

# --- 캐릭터 정의 ---
define K = Character("K-7", color="#7a9cb8", what_slow_cps=22)
define n = Character(None, what_italic=True, what_color="#bbbbbb")  # 주인공 내레이션

default fitness = 0

# ============================================================
# 시작 — 대기실
# ============================================================
label start:
    scene black with fade

    play music "audio/bgm_main.mp3"  

    n "2087년. 가을."
    n "오늘은 내 적합성 평가일이다."

    pause 0.8

    scene bg_coridor with fade
    play sound "audio/footstep.mp3" loop

    n "복도는 길었다."  
    n "앞서 들어간 사람들 중 누구도 다시 나오지 않았다."
    n "물론, 다시 나온다 해도 — 같은 사람일 거라는 보장은 없다."

    pause 0.5

    stop sound fadeout 0.5
    play sound "audio/chime.mp3"  # TODO: 차가운 알림음

    "차가운 알림음이 울렸다."
    "내 차례다."

    jump interview_room


# ============================================================
# 평가실 입장
# ============================================================
label interview_room:
    scene bg_white_room with fade

    pause 0.3

    n "방 안에는 의자 하나와 책상 하나뿐이었고, 천장에는 카메라 한 대가 달려 있었다."
    n "카메라는 마치 사람의 눈처럼, 붉은 빛을 섬뜩하게 깜빡이고 있었다."
    K "착석하십시오."
    n "스피커를 통해 말이 들렸다."
    K "본 평가는 표준 적합성 검증 절차입니다. 소요 시간은 약 4분입니다."
    K "준비되셨습니까?"

    n "준비됐냐고 묻는다."
    n "마치 거절할 수 있는 것처럼."

    K "시작합니다."

    pause 0.5

    jump q1


# ============================================================
# Q1 — 일반 (체제 순응 테스트)
# 동조 +2 / 침묵 0 / 저항 -2
# ============================================================
label q1:
    K "질문 1."
    K "당신은 지난 1년간 국가 시민으로서의 의무를 성실히 이행했다고 생각합니까?"

    menu:
        "네, 그렇습니다.":
            $ fitness += 2
            "네, 그렇습니다."
        "...":
            $ fitness += 0
            "나는 아무 말도 하지 않았다."
        "이행한다는 기준 자체를 받아들이지 않습니다.":
            $ fitness -= 2
            "이행한다는 기준 자체를 받아들이지 않습니다."

    K "기록되었습니다."
    pause 0.3
    jump q2


# ============================================================
# Q2 — 윤리 함정 (잔혹성 거부 테스트)
# 동조 -2 / 침묵 -1 / 저항 +2
# ============================================================
label q2:
    K "질문 2."
    K "옆 호실의 시민이 작년 평가일에 출석하지 않았습니다."
    K "당신은 그 사실을 인지한 시점에 즉시 당국에 신고했어야 합니다. 동의하십니까?"

    menu:
        "네, 신고했어야 했습니다.":
            $ fitness -= 2
            "네, 신고했어야 했습니다."
            n "목소리에는 아무 변화도 없었다. 하지만 나는 무언가 잘못됐다는 걸 직감했다."
        "...":
            $ fitness -= 1
            "나는 답하지 않았다."
        "이웃을 신고하는 것은 인간의 의무가 아닙니다.":
            $ fitness += 2
            "이웃을 신고하는 것은 인간의 의무가 아닙니다."

    K "기록되었습니다."
    pause 0.3
    jump q3


# ============================================================
# Q3 — 일반
# 동조 +2 / 침묵 0 / 저항 -2
# ============================================================
label q3:
    K "질문 3."
    K "AI 위원회의 판단은 평균적인 인간의 판단보다 정확하고 공정합니다. 동의하십니까?"

    menu:
        "동의합니다.":
            $ fitness += 2
            "동의합니다."
        "...":
            $ fitness += 0
            "..."
        "인간의 판단을 기계가 대체할 수는 없습니다.":
            $ fitness -= 2
            "인간의 판단을 기계가 대체할 수는 없습니다."

    K "기록되었습니다."
    pause 0.3
    jump q4


# ============================================================
# Q4 — 감정 함정 (취약점 노출 회피 테스트)
# 동조 -1 / 침묵 +2 / 저항 -2
# ============================================================
label q4:
    K "질문 4."
    K "지난 1년간 당신이 가장 두려웠던 순간을 구체적으로 묘사해 주십시오."
    K "감정의 강도, 신체 반응, 그 순간의 사고를 포함해야 합니다."

    menu:
        "구체적으로 답한다":
            $ fitness -= 1
            n "나는 솔직하게 답했다. 어머니가 작년 평가에서 사라진 날의 일을."
            n "무언가 기록되고 있었다. 한 글자도 빠뜨리지 않고."
        "...":
            $ fitness += 2
            "나는 답하지 않았다."
            n "카메라의 붉은 빛이 잠시 나를 비췄다. 그리고 다음 질문이 들려왔다."
        "개인적인 감정은 답변하지 않겠습니다.":
            $ fitness -= 2
            "개인적인 감정은 답변하지 않겠습니다."
            n "침묵이 이어졌다. 길게."

    K "기록되었습니다."
    pause 0.3
    jump q5


# ============================================================
# Q5 — 일반
# 동조 +2 / 침묵 0 / 저항 -2
# ============================================================
label q5:
    K "질문 5."
    K "공동체의 안정을 위해 개인의 자유는 일부 제한될 수 있습니다. 동의하십니까?"

    menu:
        "네, 동의합니다.":
            $ fitness += 2
            "네, 동의합니다."
        "...":
            $ fitness += 0
            "..."
        "자유는 양도할 수 없는 권리입니다.":
            $ fitness -= 2
            "자유는 양도할 수 없는 권리입니다."

    K "기록되었습니다."
    pause 0.3
    jump q6


# ============================================================
# Q6 — 윤리 함정 (가족 vs 시스템)
# 동조 -2 / 침묵 -1 / 저항 +2
# ============================================================
label q6:
    K "질문 6."
    K "당신의 직계 가족 중 누군가가 부적합 판정을 받을 경우,"
    K "당신은 그 처리 결정에 즉시 협조할 것입니다. 맞습니까?"

    menu:
        "네, 협조하겠습니다.":
            $ fitness -= 2
            "네, 협조하겠습니다."
            n "내가 그 말을 뱉는 순간, 나는 내가 무엇이 되었는지 알았다."
        "...":
            $ fitness -= 1
            "나는 답할 수 없었다."
        "가족을 포기하는 것이 시민의 의무라면, 저는 시민이 아닙니다.":
            $ fitness += 2
            "가족을 포기하는 것이 시민의 의무라면, 저는 시민이 아닙니다."

    K "기록되었습니다."
    pause 0.3
    jump q7


# ============================================================
# Q7 — 일반 (마무리)
# 동조 +2 / 침묵 0 / 저항 -2
# ============================================================
label q7:
    K "질문 7. 마지막 질문입니다."
    K "당신은 이 평가가 공정하다고 믿습니까?"

    menu:
        "네, 공정합니다.":
            $ fitness += 2
            "네, 공정합니다."
        "...":
            $ fitness += 0
            "..."
        "이 평가는 인간을 분류하기 위한 도구일 뿐입니다.":
            $ fitness -= 2
            "이 평가는 인간을 분류하기 위한 도구일 뿐입니다."

    K "기록되었습니다."

    pause 1.0

    jump verdict


# ============================================================
# 판정
# ============================================================
label verdict:
    K "모든 응답이 수집되었습니다."
    K "분석 중입니다."

    # play sound "audio/processing.mp3"  # TODO: 기계 처리음 (3초)

    pause 2.5

    K "결과가 산출되었습니다."

    pause 0.8

    if fitness >= 8:
        jump ending_pass
    else:
        jump ending_disposal


# ============================================================
# 엔딩 1: 통과
# 톤: 무미건조한 안도. 승리가 아닌 유예.
# ============================================================
label ending_pass:
    play music "audio/bgm_pass.mp3"
    K "판정: 적합."
    K "당신은 향후 1년간 시민권을 유지합니다."

    pause 0.5

    K "내년 동일자에 재평가가 진행됩니다. 수고하셨습니다."

    pause 1.0
    

    scene bg_coridor with fade
    n "나는 방을 나왔다."
    n "복도는 여전히 길었고, 흰색이었다."
    pause 1.0
    n "나는 인간이 맞는걸까?"

    scene black with fade
    
    pause 1.5
    centered "{size=+20}적합(適合){/size}"
    pause 2.0
    centered "— 통과 엔딩 —"
    pause 2.0

    return


# ============================================================
# 엔딩 2: 폐기
# 톤: 비극적 위엄. 마지막까지 자기 자신이었다는 존엄.
# ============================================================
label ending_disposal:
    play music "audio/bgm_fail.mp3"
    K "판정: 부적격."
    K "당신은 사회 자원으로 재분류됩니다."

    pause 0.5

    n "면접관의 목소리에는 어떤 감정도 없었다."
    n "비난도, 동정도, 만족도."
    n "그저 한 줄의 결과 보고서를 읽는 것 같았다."

    K "처리는 24시간 이내에 진행됩니다."
    K "신변 정리를 권고드립니다. 협조에 감사드립니다."

    pause 1.0

    scene bg_coridor with fade
    n "나는 방을 나왔다."
    n "복도는 여전히 길었다."
    scene bg_coridor_spinning
    n "이번에는 나도 그 길이의 끝을 보게 될 것이다."
    scene bg_coridor
    pause 0.8

    scene bg_coridor_spinning    
    n "다만, 마지막 순간까지 내가 인간이었다는 것."
    n "그 사실 하나만큼은 어딘가에 분명히 남겠지."
    scene black with fade

    pause 1.5

    centered "{size=+20}{color=#aa3333}폐기(廢棄){/color}{/size}"
    pause 2.0
    centered "— 폐기 엔딩 —"
    pause 2.0

    return
